# Copia questo file come plotino.env e compila i valori (plotino.env non va committato).
# start.sh carica plotino.env automaticamente prima di avviare il bridge.

# --- Sicurezza bridge (stesso valore va messo nell’interfaccia Impostazioni → Chiave condivisa) ---
PUBLISH_SECRET=

# --- X (Twitter) API v2 — Bearer OAuth 2 utente con scope tweet.write ---
X_BEARER_TOKEN=

# --- Facebook Page — Graph API (feed sulla pagina) ---
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# --- LinkedIn — UGC Posts ---
LINKEDIN_ACCESS_TOKEN=
# Esempio: urn:li:person:xxxxxxxx
LINKEDIN_AUTHOR_URN=

# --- Instagram Graph (richiede estensioni sul bridge per upload da URL) ---
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# --- TikTok Content Posting (stub nel bridge) ---
TIKTOK_ACCESS_TOKEN=

# --- YouTube Data API — upload richiede OAuth + progetto GCP (stub sul bridge) ---
# YOUTUBE_CLIENT_ID=
# YOUTUBE_REFRESH_TOKEN=

# --- IA — generazione post (POST /generate); alternativa: chiave nel browser in Impostazioni ---
OPENAI_API_KEY=
# AI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=
